# ============================================================================
# KIMI MSK Agent — Environment Variables
# Copy this to .env.local and fill in your values
# ============================================================================

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (HIPAA BAA required for production)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# CMS ACCESS Model APIs (available after July 2026 launch)
CMS_API_BASE_URL=https://api.cms.gov/access/v1
CMS_CLIENT_ID=
CMS_CLIENT_SECRET=

# ElevenLabs Text-to-Speech (Voice Orb feature)
ELEVENLABS_API_KEY=

# YouTube Data API (Exercise video demonstrations)
YOUTUBE_API_KEY=

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
